rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is an admin
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admin_users/$(request.auth.uid));
    }

    // Admin Users collection: Only admins can manage this list
    match /admin_users/{userId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Core training collections: Admins have full access
    match /programs/{programId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
      
      match /days/{dayId} {
        allow read: if request.auth != null;
        allow write: if isAdmin();
        
        match /workouts/{workoutId} {
          allow read: if request.auth != null;
          allow write: if isAdmin();
        }
      }
    }

    // Clients collection: Admins can manage, users can read their own
    match /clients/{clientId} {
      allow read: if request.auth != null && (isAdmin() || request.auth.uid == clientId);
      allow write: if isAdmin();
    }

    // Equipment collection: Admins can manage
    match /equipment/{item} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Assignments collection
    match /assignments/{assignmentId} {
      allow read: if request.auth != null && (isAdmin() || resource.data.clientId == request.auth.uid);
      allow write: if isAdmin();
    }

    // Activity collection: Admins can read
    match /activity/{activityId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}

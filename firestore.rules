rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is an admin
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admin_users/$(request.auth.uid));
    }

    // Admin Users collection: Only admins can manage this list
    match /admin_users/{userId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Core training collections: Admins have full access
    match /programs/{programId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
      
      match /days/{dayId} {
        allow read: if request.auth != null;
        allow write: if isAdmin();
        
        match /workouts/{workoutId} {
          allow read: if request.auth != null;
          allow write: if isAdmin();
        }
      }
    }

    // Clients collection: Admins can manage, users can manage their own
    match /clients/{clientId} {
      allow read: if request.auth != null && (isAdmin() || request.auth.uid == clientId);
      // Allow creation by self (for registration sync)
      allow create: if request.auth != null && request.auth.uid == clientId;
      // Allow update by self (but not is_active status) or admin
      allow update: if request.auth != null && (
        isAdmin() || 
        (request.auth.uid == clientId && request.resource.data.is_active == resource.data.is_active)
      );
      allow delete: if isAdmin();
    }

    // Equipment collection: Admins can manage
    match /equipment/{item} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Assignments collection: Users can read their own
    match /assignments/{assignmentId} {
      allow read: if request.auth != null && (isAdmin() || assignmentId == request.auth.uid || resource.data.clientId == request.auth.uid);
      allow write: if isAdmin();
    }

    // Activity collection: Admins can read
    match /activity/{activityId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Training History collection
    match /training_history/{historyId} {
      allow read: if request.auth != null && (isAdmin() || resource.data.uid == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
